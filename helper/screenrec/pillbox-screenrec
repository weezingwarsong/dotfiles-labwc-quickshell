#!/bin/bash
# pillbox-screenrec — screen recorder helper for Pillbox (v2)
#
# Wraps gpu-screen-recorder in two modes that map to Pillbox's Single/Replay UI.
#
# ── MODE OVERVIEW ──────────────────────────────────────────────────────────────
#
# oneshot  No daemon. gsr spawns when the user starts recording and exits when
#          stopped. SIGINT saves and exits. Any capture source supported.
#          Lifecycle: spawn → record → SIGINT → save → exit.
#
# replay   Permanent daemon. gsr spawns at Quickshell startup and runs
#          indefinitely, maintaining a rolling in-RAM buffer. Signals toggle
#          recording-to-file and trigger buffer saves independently.
#          Lifecycle: spawn at startup → buffer always hot → signals as needed
#                     → SIGINT only on emergency (exits WITHOUT saving buffer).
#
# ── USAGE ──────────────────────────────────────────────────────────────────────
#
#   pillbox-screenrec oneshot|replay [options]
#
# Sub-mode oneshot:
#   --source screen|region  (default: screen)
#   --region WxH+X+Y        (coords from slurp; required when source=region)
#   --fps N                 (default: 60)
#   --dir PATH              (output dir for recordings)
#
# Sub-mode replay:
#   --fps N
#   --dir PATH              (output dir for toggle-recordings, passed as gsr -ro)
#   --replay-dir PATH       (output dir for replay clips, passed as gsr -o)
#   --replay-secs N         (replay buffer size in seconds, default: 300)
#
# Audio (both modes):
#   --audio none            no audio (default)
#   --audio system          desktop audio  (-a default_output)
#   --audio mic             microphone     (-a default_input)
#   --audio both            desktop + mic  (-a default_output -a default_input)
#   --audio <gsr-source>    raw gsr source string (device:name, app:name, etc.)
#
# ── GSR SIGNALS ────────────────────────────────────────────────────────────────
#
# oneshot only:
#   SIGINT     Stop and save recording → -sc callback fires, gsr exits
#   SIGUSR2    Pause / unpause  (man: "not for streaming/replay")
#
# replay only:
#   SIGRTMIN   Toggle recording-to-file in -ro dir (start if idle, stop+save if active)
#              → -sc fires with type "regular" on stop+save
#   SIGUSR1    Save full replay buffer to -o dir → -sc fires with type "replay"
#   SIGRTMIN+1 Save last 10 s to -o dir
#   SIGRTMIN+2 Save last 30 s
#   SIGRTMIN+3 Save last 60 s
#   SIGRTMIN+4 Save last 5 min
#   SIGRTMIN+5 Save last 10 min
#   SIGRTMIN+6 Save last 30 min
#   SIGINT     Emergency exit — NO save, buffer discarded, gsr exits
#
# NOTE: SIGUSR2 (pause) is documented as "not for streaming/replay" in the gsr
# man page. It is wired in the CTL loop below but has no effect in replay mode.
#
# ── GSR -sc CALLBACK ───────────────────────────────────────────────────────────
#
# gsr calls  pillbox-screenrec-saved <PATH> <TYPE>  after each file save.
# TYPE is one of: regular (recording-to-file), replay (buffer save), screenshot.
# The callback writes "TYPE:PATH" to the screenrec-notify FIFO.
# A background reader here translates that to the stdout protocol below.
#
# ── STDOUT PROTOCOL (read by ScreenrecProcess.qml via SplitParser) ─────────────
#
#   screenrec:started             gsr is alive and ready
#   screenrec:stopped:PATH        recording-to-file ended and saved (oneshot or SIGRTMIN)
#   screenrec:replay:saved:PATH   replay buffer clip saved (SIGUSR1 or SIGRTMIN+N)
#   screenrec:error:REASON        something went wrong
#
# ── CTL FIFO: ~/.local/share/pillbox/screenrec-ctl ────────────────────────────
#
#   Both modes : stop            → SIGINT
#   Both modes : pause           → SIGUSR2  (no-op in replay mode, see note above)
#   replay only: toggleRec       → SIGRTMIN
#   replay only: saveReplay      → SIGUSR1
#   replay only: saveReplay:10   → SIGRTMIN+1
#   replay only: saveReplay:30   → SIGRTMIN+2
#   replay only: saveReplay:60   → SIGRTMIN+3
#   replay only: saveReplay:300  → SIGRTMIN+4
#   replay only: saveReplay:600  → SIGRTMIN+5
#   replay only: saveReplay:1800 → SIGRTMIN+6

set -o noglob   # prevent glob expansion in kill signal arithmetic

SUBMODE="${1:-oneshot}"
shift

# ── defaults ──────────────────────────────────────────────────────────────────

SOURCE="screen"
REGION_COORDS=""
FPS=60
AUDIO="none"
SAVE_DIR="$HOME/.config/pillbox/media/Recordings"
REPLAY_DIR="$HOME/.config/pillbox/media/Replays"
REPLAY_SECS=300

# ── args ──────────────────────────────────────────────────────────────────────

while [ $# -gt 0 ]; do
    case "$1" in
        --source)      SOURCE="$2";         shift 2 ;;
        --region)      REGION_COORDS="$2";  shift 2 ;;
        --fps)         FPS="$2";            shift 2 ;;
        --audio)       AUDIO="$2";          shift 2 ;;
        --dir)         SAVE_DIR="$2";       shift 2 ;;
        --replay-dir)  REPLAY_DIR="$2";     shift 2 ;;
        --replay-secs) REPLAY_SECS="$2";    shift 2 ;;
        *)             shift ;;
    esac
done

case "$SUBMODE" in
    oneshot|replay) ;;
    *) echo "screenrec:error:unknown sub-mode '$SUBMODE' (expected oneshot|replay)"; exit 1 ;;
esac

# ── paths ─────────────────────────────────────────────────────────────────────

PILLBOX_RUN="$HOME/.local/share/pillbox"
CTL_FIFO="$PILLBOX_RUN/screenrec-ctl"
NOTIFY_FIFO="$PILLBOX_RUN/screenrec-notify"
PID_FILE="$PILLBOX_RUN/screenrec.pid"
GSR_ERR="/tmp/pillbox-gsr-err"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SC_CALLBACK="$SCRIPT_DIR/pillbox-screenrec-saved"

# ── SIGRTMIN ──────────────────────────────────────────────────────────────────

_RTMIN=$(python3 -c 'import signal; print(int(signal.SIGRTMIN))' 2>/dev/null || echo 34)

# ── audio flags ───────────────────────────────────────────────────────────────
# Returns zero, one, or two -a flags for gsr based on --audio value.
# none/""         → (nothing)
# system          → -a default_output
# mic             → -a default_input
# both            → -a default_output -a default_input
# anything else   → -a <value>  (raw gsr source string, e.g. device:name)

_audio_flags() {
    case "$AUDIO" in
        none|"") ;;
        system)  printf '%s' "-a default_output" ;;
        mic)     printf '%s' "-a default_input" ;;
        both)    printf '%s' "-a default_output -a default_input" ;;
        *)       printf '%s' "-a $AUDIO" ;;
    esac
}

# ── helpers ───────────────────────────────────────────────────────────────────

NOTIFY_READER_PID=""
WATCHER_PID=""

die() {
    echo "screenrec:error:$1"
    cleanup
    exit 1
}

cleanup() {
    # Close our write-end hold on the notify FIFO so the reader drains to EOF.
    # Wait for the reader to finish emitting any pending messages before we exit.
    exec 4>&- 2>/dev/null || true
    [ -n "$NOTIFY_READER_PID" ] && wait "$NOTIFY_READER_PID" 2>/dev/null || true
    exec 3>&- 2>/dev/null || true
    [ -n "$WATCHER_PID" ] && kill "$WATCHER_PID" 2>/dev/null || true
    rm -f "$CTL_FIFO" "$NOTIFY_FIFO" "$PID_FILE"
}

_emergency_stop() {
    kill -INT "$GSR_PID" 2>/dev/null || true
    wait "$GSR_PID" 2>/dev/null || true
    cleanup
}
trap _emergency_stop EXIT

# Guard: second instance
if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
    die "already recording (pid $(cat "$PID_FILE"))"
fi

# ── setup ─────────────────────────────────────────────────────────────────────

mkdir -p "$SAVE_DIR" "$REPLAY_DIR" "$PILLBOX_RUN" || die "cannot create output directories"

TIMESTAMP="$(date +%Y-%m-%d_%H-%M-%S)"

rm -f "$CTL_FIFO" "$NOTIFY_FIFO"
mkfifo "$CTL_FIFO"    || die "cannot create CTL FIFO"
mkfifo "$NOTIFY_FIFO" || die "cannot create notify FIFO"

# ── notify FIFO reader ────────────────────────────────────────────────────────
# Hold the write end open (exec 4<>) so pillbox-screenrec-saved can open for
# writing without blocking, and so the reader doesn't get spurious EOF.
# The subshell closes its inherited write end before reading, ensuring EOF is
# delivered when the parent closes fd 4 in cleanup().

exec 4<>"$NOTIFY_FIFO"

(
    exec 4>&-   # subshell: drop write end; only parent controls EOF
    while IFS= read -r msg; do
        type="${msg%%:*}"
        path="${msg#*:}"
        case "$type" in
            regular) echo "screenrec:stopped:$path" ;;
            replay)  echo "screenrec:replay:saved:$path" ;;
        esac
    done
) < "$NOTIFY_FIFO" &
NOTIFY_READER_PID=$!

# ── build gsr command ─────────────────────────────────────────────────────────

case "$SUBMODE" in
    oneshot)
        case "$SOURCE" in
            region)
                if [ -n "$REGION_COORDS" ]; then
                    CAPTURE="-w region -region $REGION_COORDS"
                else
                    RC="$(slurp -f '%wx%h+%x+%y' 2>/dev/null)" || { cleanup; exit 0; }
                    [ -n "$RC" ] || { cleanup; exit 0; }
                    CAPTURE="-w region -region $RC"
                fi
                ;;
            *)
                CAPTURE="-w screen"
                ;;
        esac

        OUTPUT="$SAVE_DIR/recording_${TIMESTAMP}.mp4"

        AUDIO_FLAGS="$(_audio_flags)"
        # shellcheck disable=SC2086
        gpu-screen-recorder \
            $CAPTURE \           # -w screen | -w region -region WxH+X+Y
            $AUDIO_FLAGS \       # zero, one, or two -a flags; empty = no audio
            -f "$FPS" \          # frame rate cap
            -c mp4 \             # container format
            -o "$OUTPUT" \       # output file path (single file, not a directory)
            -sc "$SC_CALLBACK" \ # called with PATH TYPE after each save
            -v no \              # suppress fps/damage chatter on stdout
            >/dev/null 2>"$GSR_ERR" &
        ;;

    replay)
        AUDIO_FLAGS="$(_audio_flags)"
        # shellcheck disable=SC2086
        gpu-screen-recorder \
            -w screen \          # replay mode is screen-only (region not supported with -r)
            $AUDIO_FLAGS \
            -f "$FPS" \
            -c mp4 \
            -r "$REPLAY_SECS" \  # rolling replay buffer size in seconds; kept in RAM
            -bm cbr \            # constant bitrate — predictable RAM usage for the buffer
            -q 40000 \           # 40 Mbps CBR (man page recommended value for replay)
            -o "$REPLAY_DIR" \   # directory: replay buffer saves (SIGUSR1, SIGRTMIN+N) go here
            -ro "$SAVE_DIR" \    # directory: toggle-recordings (SIGRTMIN) go here
            -sc "$SC_CALLBACK" \ # called with PATH TYPE after each save; TYPE = regular|replay
            -v no \
            >/dev/null 2>"$GSR_ERR" &
        ;;
esac

GSR_PID=$!
echo "$GSR_PID" > "$PID_FILE"

# Brief pause — let gsr initialise
sleep 0.5

if ! kill -0 "$GSR_PID" 2>/dev/null; then
    die "gpu-screen-recorder failed to start: $(tail -1 "$GSR_ERR" 2>/dev/null)"
fi

echo "screenrec:started"

# ── gsr death watcher ─────────────────────────────────────────────────────────
# Polls until gsr exits, then unblocks the CTL loop via a sentinel message.

(
    while kill -0 "$GSR_PID" 2>/dev/null; do sleep 0.5; done
    echo "__gsr_exited__" > "$CTL_FIFO" 2>/dev/null || true
) &
WATCHER_PID=$!

# ── CTL loop ──────────────────────────────────────────────────────────────────
# Keep a write fd on CTL_FIFO (fd 3) open so reads never get spurious EOF.

exec 3<>"$CTL_FIFO"

while IFS= read -r CMD <&3; do
    case "$CMD" in

        stop)
            kill -INT "$GSR_PID" 2>/dev/null || true
            wait "$GSR_PID" 2>/dev/null
            kill "$WATCHER_PID" 2>/dev/null || true
            WATCHER_PID=""
            # cleanup() closes fd 4, drains notify reader, then exits.
            # For oneshot: -sc fired before gsr exited → reader emits stopped.
            # For replay: SIGINT exits without save → reader emits nothing.
            break
            ;;

        pause)
            kill -USR2 "$GSR_PID" 2>/dev/null || echo "screenrec:error:pause: gsr not running"
            ;;

        toggleRec)
            if [ "$SUBMODE" != "replay" ]; then
                echo "screenrec:error:toggleRec requires replay mode"
                continue
            fi
            kill -"$_RTMIN" "$GSR_PID" 2>/dev/null || echo "screenrec:error:toggleRec failed"
            ;;

        saveReplay)
            [ "$SUBMODE" != "replay" ] && { echo "screenrec:error:saveReplay requires replay mode"; continue; }
            kill -USR1 "$GSR_PID" 2>/dev/null || echo "screenrec:error:saveReplay failed"
            ;;

        saveReplay:10)
            kill -$(( _RTMIN + 1 )) "$GSR_PID" 2>/dev/null || echo "screenrec:error:saveReplay:10 failed" ;;
        saveReplay:30)
            kill -$(( _RTMIN + 2 )) "$GSR_PID" 2>/dev/null || echo "screenrec:error:saveReplay:30 failed" ;;
        saveReplay:60)
            kill -$(( _RTMIN + 3 )) "$GSR_PID" 2>/dev/null || echo "screenrec:error:saveReplay:60 failed" ;;
        saveReplay:300)
            kill -$(( _RTMIN + 4 )) "$GSR_PID" 2>/dev/null || echo "screenrec:error:saveReplay:300 failed" ;;
        saveReplay:600)
            kill -$(( _RTMIN + 5 )) "$GSR_PID" 2>/dev/null || echo "screenrec:error:saveReplay:600 failed" ;;
        saveReplay:1800)
            kill -$(( _RTMIN + 6 )) "$GSR_PID" 2>/dev/null || echo "screenrec:error:saveReplay:1800 failed" ;;

        __gsr_exited__)
            kill "$WATCHER_PID" 2>/dev/null || true
            WATCHER_PID=""
            if [ "$SUBMODE" = "oneshot" ] && [ -f "$OUTPUT" ] && [ -s "$OUTPUT" ]; then
                # gsr exited cleanly on its own (unusual but not an error); -sc should
                # have fired. Let the notify reader emit the stopped message.
                :
            else
                echo "screenrec:error:gsr exited unexpectedly: $(tail -1 "$GSR_ERR" 2>/dev/null)"
            fi
            break
            ;;

        *)
            echo "screenrec:error:unknown CTL command: $CMD"
            ;;
    esac
done

exec 3>&-
# EXIT trap fires → _emergency_stop → cleanup
exit 0
