#!/bin/sh
# pillbox-screenrec-saved — gpu-screen-recorder -sc callback (v2)
#
# Called by gsr after each file is finalised.
# Args: $1=absolute path, $2=type (regular|replay|screenshot)
#
# Writes TYPE:PATH to the screenrec-notify FIFO for pillbox-screenrec to read
# and forward to stdout as the appropriate screenrec:stopped / screenrec:replay:saved
# protocol message.

FILEPATH="$1"
TYPE="$2"
NOTIFY_FIFO="$HOME/.local/share/pillbox/screenrec-notify"

case "$TYPE" in
    regular|replay)
        [ -p "$NOTIFY_FIFO" ] && printf '%s:%s\n' "$TYPE" "$FILEPATH" > "$NOTIFY_FIFO"
        ;;
esac
